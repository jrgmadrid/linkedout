{
  "manifest_version": 3,
  "name": "Better LinkedIn",
  "version": "2.0.0",
  "description": "Filters the LinkedIn feed: promoted posts, social spillover, reposts, and more.",
  "permissions": ["storage"],
  "host_permissions": ["https://api.deepseek.com/*", "https://www.linkedin.com/*"],
  "background": {
    "service_worker": "worker.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Better LinkedIn"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["filters.js", "slop.js", "content.js", "harvest.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
