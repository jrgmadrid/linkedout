{
  "manifest_version": 3,
  "name": "LinkedOut",
  "version": "2.0.0",
  "description": "Filters the LinkedIn feed: promoted posts, social spillover, reposts, and more.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://api.deepseek.com/*", "https://www.linkedin.com/*"],
  "background": {
    "service_worker": "worker.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    },
    "default_popup": "popup.html",
    "default_title": "LinkedOut"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["filters.js", "slop.js", "content.js", "harvest.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
